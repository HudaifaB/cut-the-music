{
  "manifest_version": 3,
  "name": "Cut The Music",
  "description": "A YouTube-focused extension for reducing background music.",
  "version": "0.1.0",
  "action": {
    "default_title": "Cut The Music",
    "default_popup": "popup.html"
  },
  "permissions": [
    "activeTab",
    "storage",
    "tabCapture",
    "offscreen"
  ],
  "host_permissions": [
    "https://www.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "audio-worklet.js"
      ],
      "matches": [
        "https://www.youtube.com/*"
      ]
    }
  ]
}
